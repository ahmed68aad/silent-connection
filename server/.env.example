NODE_ENV=development
PORT=3000

CLIENT_ORIGIN=https://silent-connection-cli.vercel.app
# Optional comma-separated list for deployed frontends, previews, etc.
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_SECRET=dev-only-change-me-please-32-chars

MONGO_URI=mongodb://127.0.0.1:27017/silent

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Silent Connection <your-email@gmail.com>"
