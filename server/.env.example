NODE_ENV=production
PORT=3000

# Frontend origin allowed by CORS. Use your deployed client URL.
# CLIENT_URL is also supported for compatibility.
CLIENT_ORIGIN=https://your-client-domain.com

# Use a strong secret, at least 32 characters.
JWT_SECRET=replace-with-a-long-random-secret

# MongoDB connection string.
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/silent-connection

# Cloudinary is required for post image uploads in production.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SMTP is required for email verification in production.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@your-domain.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Silent Connection <no-reply@your-domain.com>"
